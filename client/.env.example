# ZeroBudget SPA build-time configuration (Vite).
#
# Copy to `.env.local` for local development. In production these are supplied by the
# deploy workflow (GitHub Actions) — see .github/workflows/deploy.yml. Only variables
# prefixed with VITE_ are exposed to the browser bundle.

# Google Analytics 4 measurement ID (e.g. G-XXXXXXXXXX).
# Leave UNSET to disable analytics entirely (no GA script is ever loaded). When set,
# analytics still only runs if the server's `Analytics` feature flag is on AND the user
# grants cookie consent. Measurement IDs are public, so this is not a secret.
VITE_GA_MEASUREMENT_ID=
