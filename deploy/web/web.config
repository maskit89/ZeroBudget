<?xml version="1.0" encoding="utf-8"?>
<!--
  IIS configuration for the FRONT site ("ZeroBudget") that serves the React SPA
  (client/dist) and reverse-proxies API calls to the Kestrel/ANCM API site.

  Requires on the server:
    * URL Rewrite 2.1 module
    * Application Request Routing (ARR) 3.0 with server-level proxy ENABLED
      (Setup-Server.ps1 turns it on).

  This file is deployed automatically as part of the release (CI copies it into
  release/web/). TLS is terminated here by IIS; win-acme adds the http->https
  redirect + binding, so no HTTPS rule is hard-coded below.
-->
<configuration>
  <system.webServer>

    <rewrite>
      <rules>
        <!-- 1. Reverse-proxy /api/* to the internal API site via ARR. -->
        <rule name="ApiProxy" stopProcessing="true">
          <match url="^api/(.*)" />
          <!-- 127.0.0.1, not localhost: the API site binds to IPv4 only, and
               localhost can resolve to ::1 (IPv6) first, which would 502. -->
          <action type="Rewrite" url="http://127.0.0.1:5000/api/{R:1}" />
          <!-- No <serverVariables>: URL Rewrite returns HTTP 500 when a rule sets
               a server variable that isn't in the (server-level) allowed list. -->
        </rule>

        <!-- 2. SPA fallback: anything that isn't a real file or directory is a
                client-side route, so serve index.html and let React Router handle it. -->
        <rule name="SpaFallback" stopProcessing="true">
          <match url=".*" />
          <conditions logicalGrouping="MatchAll">
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
            <add input="{REQUEST_FILENAME}" matchType="IsDirectory" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.html" />
        </rule>
      </rules>
    </rewrite>

    <!-- Long-cache the content-hashed Vite assets; never cache index.html so a
         new deploy is picked up immediately. -->
    <staticContent>
      <remove fileExtension=".woff2" />
      <mimeMap fileExtension=".woff2" mimeType="font/woff2" />
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
    </staticContent>

    <httpProtocol>
      <customHeaders>
        <add name="X-Content-Type-Options" value="nosniff" />
        <add name="Referrer-Policy" value="strict-origin-when-cross-origin" />
        <add name="X-Frame-Options" value="DENY" />
        <!-- Switch off powerful browser features the app never uses. -->
        <add name="Permissions-Policy" value="accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()" />
        <!--
          Content-Security-Policy — now ENFORCED (was Report-Only). The allow-list is the full set
          of origins this app actually loads: same-origin for our own scripts/styles/XHR (the theme
          bootstrap is /theme-init.js, so there is NO inline script); gtag.js from googletagmanager.com
          and GA beacons to *.google-analytics.com / *.analytics.google.com (Google Signals is off, so
          no ad/doubleclick origins are needed); and Google Fonts — the CSS from fonts.googleapis.com
          and the font files from fonts.gstatic.com — for the Inter typeface (@import in index.css).
          'unsafe-inline' applies to STYLES only (React inline style attributes), never to scripts.
          To debug a suspected over-block, temporarily rename this header back to
          "Content-Security-Policy-Report-Only". Add HSTS once the site is served over HTTPS.
        -->
        <add name="Content-Security-Policy" value="default-src 'self'; script-src 'self' https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' data: https://*.google-analytics.com; font-src 'self' https://fonts.gstatic.com; connect-src 'self' https://*.google-analytics.com https://*.analytics.google.com https://www.googletagmanager.com; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'" />
      </customHeaders>
    </httpProtocol>

    <urlCompression doStaticCompression="true" doDynamicCompression="true" />

  </system.webServer>

  <location path="index.html">
    <system.webServer>
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
    </system.webServer>
  </location>
</configuration>
